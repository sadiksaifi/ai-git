---
import { faq } from "@ai-git/content/web"
---

<section class="faq" aria-labelledby="faq-heading">
  <div class="inner">
    <header class="section-head">
      <h2 id="faq-heading">Questions.</h2>
    </header>
    <dl>
      {
        faq.map((q) => (
          <div class="item">
            <dt>{q.question}</dt>
            <dd>{q.answer}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .faq {
    padding: var(--section-y) var(--container-pad);
    border-top: 1px solid var(--color-border);
  }
  .inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    gap: var(--section-header-gap);
    justify-items: center;
    text-align: center;
  }
  .section-head {
    display: grid;
    gap: var(--section-title-gap);
    justify-items: center;
  }
  h2 {
    font-size: var(--text-2xl);
  }
  dl {
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
    max-width: 44rem;
    width: 100%;
    text-align: left;
  }
  .item {
    display: grid;
    gap: var(--space-2);
  }
  dt {
    font-size: var(--text-base);
    color: var(--color-fg);
    font-weight: 500;
  }
  dd {
    margin: 0;
    color: var(--color-fg-dim);
    font-size: var(--text-base);
    line-height: 1.55;
  }
</style>
