---
import { nav } from "@ai-git/content/web"

const iconPath: Record<string, string> = {
  github:
    "M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.9.1 3.2.9.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.1.9 2.3v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3",
}
---

<nav class="nav" aria-label="Primary">
  <a href="/" class="wordmark">ai-git</a>
  <ul>
    {
      nav.map((link) => {
        const icon = iconPath[link.label.toLowerCase()]
        return (
          <li>
            <a
              href={link.href}
              rel={link.external ? "noopener noreferrer" : undefined}
              target={link.external ? "_blank" : undefined}
            >
              {icon && (
                <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d={icon} />
                </svg>
              )}
              <span>{link.label}</span>
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--container-pad);
    max-width: var(--container-max);
    margin-inline: auto;
  }
  .wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: -0.02em;
  }
  ul {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  ul a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-muted);
    font-size: var(--text-sm);
    transition: color 0.15s;
  }
  ul a:where(:hover, :focus-visible) {
    color: var(--color-fg);
  }
</style>
