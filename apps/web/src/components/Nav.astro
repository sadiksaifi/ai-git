---
import { nav } from "@ai-git/content/web"
---

<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true"></span>
      <span>ai-git</span>
    </a>
    <ul class="nav-links">
      <li><a href="#how">How it works</a></li>
      <li><a href="#providers">Providers</a></li>
      <li><a href="#config">Config</a></li>
      <li><a href="#faq">FAQ</a></li>
      {
        nav.map((link) => (
          <li>
            <a
              href={link.href}
              rel={link.external ? "noopener noreferrer" : undefined}
              target={link.external ? "_blank" : undefined}
            >
              <span>{link.label}</span>
              {link.external && (
                <svg
                  aria-hidden="true"
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="7" y1="17" x2="17" y2="7" />
                  <polyline points="7 7 17 7 17 17" />
                </svg>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(10px);
    background: color-mix(in oklab, var(--color-bg) 78%, transparent);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    display: inline-block;
    width: 18px;
    height: 18px;
    position: relative;
  }
  .brand-mark::before,
  .brand-mark::after {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-accent-line);
    border-radius: 3px;
  }
  .brand-mark::after {
    transform: translate(3px, 3px);
    border-color: var(--color-fg);
  }
  .nav-links {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .nav-links a {
    color: var(--color-fg-dim);
    font-size: var(--text-sm);
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .nav-links a svg {
    display: block;
    color: var(--color-muted);
    transition: color 0.15s;
  }
  .nav-links a:where(:hover, :focus-visible) svg {
    color: var(--color-fg);
  }
  .nav-links a:where(:hover, :focus-visible) {
    color: var(--color-fg);
  }
  @media (max-width: 640px) {
    .nav-links li:not(:last-child) {
      display: none;
    }
  }
</style>
