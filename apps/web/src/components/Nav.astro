---
import { nav } from "@ai-git/content/web"

const iconPath: Record<string, string> = {
  github:
    "M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.9.1 3.2.9.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.1.9 2.3v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3",
}
---

<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true"></span>
      <span>ai-git</span>
    </a>
    <ul class="nav-links">
      <li><a href="#how">How it works</a></li>
      <li><a href="#providers">Providers</a></li>
      <li><a href="#config">Config</a></li>
      <li><a href="#faq">FAQ</a></li>
      {
        nav.map((link) => {
          const icon = iconPath[link.label.toLowerCase()]
          return (
            <li>
              <a
                href={link.href}
                rel={link.external ? "noopener noreferrer" : undefined}
                target={link.external ? "_blank" : undefined}
              >
                {icon && (
                  <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d={icon} />
                  </svg>
                )}
                <span>{link.label}</span>
              </a>
            </li>
          )
        })
      }
    </ul>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(10px);
    background: color-mix(in oklab, var(--color-bg) 78%, transparent);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    display: inline-block;
    width: 18px;
    height: 18px;
    position: relative;
  }
  .brand-mark::before,
  .brand-mark::after {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-accent-line);
    border-radius: 3px;
  }
  .brand-mark::after {
    transform: translate(3px, 3px);
    border-color: var(--color-fg);
  }
  .nav-links {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .nav-links a {
    color: var(--color-fg-dim);
    font-size: var(--text-sm);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .nav-links a:where(:hover, :focus-visible) {
    color: var(--color-fg);
  }
  @media (max-width: 640px) {
    .nav-links li:not(:last-child) {
      display: none;
    }
  }
</style>
