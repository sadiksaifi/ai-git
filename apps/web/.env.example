# Alchemy state encryption
# Generate with: openssl rand -base64 48
ALCHEMY_PASSWORD=

# Cloudflare API token (deploy credentials)
# For CI, use a minimal-scope token (see .github/workflows/deploy-web.yml).
# For local, any CF API token with Workers + DNS + SSL + Rulesets permissions works.
CLOUDFLARE_API_TOKEN=

# Bind this domain to the deploy. Omit to get a *.workers.dev URL only.
DOMAIN=ai-git.xyz
